<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create new post</title>
    <link rel="stylesheet" href="/newstyle.css">
</head>
<body>
    <div class="posting">
    <form method="post" action="/posts">
        <input placeholder="Enter username" name="username"> <br><br>
        <textarea placeholder="Write your post here" name="content"></textarea><br>
        <textarea placeholder="Post Date" name="postdate"></textarea><br>
        <button class="butt">SUBMIT</button>
    </form>
    </div>
</body>
</html>
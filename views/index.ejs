<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All posts</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Quora Posts !!</h1>
    <% for (post of posts){ %>
        <div class="posts">
            <h3 class="username">@ <%= post.username %></h3>
            <h4 class="content"><%= post.content %></h4>
            <h4 class="postdate">Date: <%= post.postdate %></h4>
            <br>
            <button>
                <a href="http://localhost:8080/posts/<%=post.id%>">See in detail</a>
            </button>
            <button>
                <a href="http://localhost:8080/posts/<%=post.id%>/edit">Edit</a>
            </button>
        </div>
    <% } %>
    <br><br>
    <button class="createnp"><a href="http://localhost:8080/posts/new">Create new post!!</a></button>
</body>
</html>